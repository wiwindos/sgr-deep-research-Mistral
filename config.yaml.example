# SGR Classic Agent (single-file edition) - Configuration Template
# Copy this file to config.yaml and fill in your API keys before running the agent.
#
# Runtime dependencies (install once):
#   pip install openai tavily-python pydantic annotated-types rich trafilatura \
#              youtube-transcript-api PyYAML
#
# Launch instructions:
#   php sgr_classic_agent.php
#   # Optional: choose interpreter → SGR_PYTHON=/path/to/python php sgr_classic_agent.php
#
# The PHP wrapper extracts an embedded Python version of the classic agent to a
# temporary directory and executes it. All configuration values below can also be
# provided via environment variables (see comments).

# OpenAI Configuration
openai:
  api_key: "your-openai-api-key-here"  # Required. Env override: OPENAI_API_KEY
  base_url: ""                         # Optional custom endpoint. Env: OPENAI_BASE_URL
  model: "gpt-4o-mini"                 # Env: OPENAI_MODEL
  max_tokens: 8000                     # Env: MAX_TOKENS
  temperature: 0.4                     # Env: TEMPERATURE

# Tavily Search Configuration
tavily:
  api_key: "your-tavily-api-key-here"  # Required. Env override: TAVILY_API_KEY

# Search Settings
search:
  max_results: 10                      # Env override: MAX_SEARCH_RESULTS

# Scraping Settings
scraping:
  enabled: false                       # Env: SCRAPING_ENABLED=true to enable full-page fetch
  max_pages: 5                         # Env: SCRAPING_MAX_PAGES
  content_limit: 1500                  # Env: SCRAPING_CONTENT_LIMIT

# Execution Settings
execution:
  max_steps: 6                         # Env: MAX_EXECUTION_STEPS
  reports_dir: "reports"               # Env: REPORTS_DIRECTORY

# Additional tips:
# - Create the reports directory before running: mkdir -p reports
# - To avoid storing config.yaml in git, keep credentials only in your local copy.
# - You can run the agent non-interactively by passing arguments that the Python
#   script understands (all CLI args after the PHP wrapper are forwarded).
